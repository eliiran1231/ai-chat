{
  "name": "ai-chat",
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng build --base-href ./ && npm run build:electron && electron .",
    "build": "ng build && npm run build:electron",
    "build:electron": "tsc --project tsconfig.electron.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "dompurify": "^3.4.1",
    "filesize": "^9.0.11",
    "lucide": "^1.8.0",
    "lucide-angular": "^1.0.0",
    "marked": "^17.0.6",
    "ngx-filesize": "^3.0.7",
    "ngx-markdown": "^21.1.0",
    "ngx-scrollbar": "^19.1.4",
    "rxjs": "~7.8.0",
    "sqlite3": "^6.0.1",
    "tslib": "^2.3.0",
    "xstate": "^5.30.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "electron": "^41.8.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
